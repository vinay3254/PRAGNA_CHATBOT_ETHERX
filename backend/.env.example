# ===================================================================
# ENVIRONMENT CONFIGURATION FOR ETHERXCHATBOT BACKEND
# ===================================================================
# Copy this file to .env and fill in the actual values
# This file documents ALL required and optional configuration

# ===================================================================
# FLASK SERVER CONFIGURATION
# ===================================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=False                    # MUST be False in production!

# Comma-separated list of allowed frontend origins (e.g.
# https://etherx-frontend.onrender.com). Defaults to "*" (any origin) when
# unset - fine for local dev, but set explicitly in production.
CORS_ALLOWED_ORIGINS=*

# Per-client-IP rate limit on /api/images/generate and /api/documents/generate
# (both unauthenticated and each triggers an LLM call/disk write). Format is
# flask-limiter syntax, e.g. "10 per hour", "5 per minute".
AI_GENERATION_RATE_LIMIT=10 per hour

# Storage backend for rate-limit counters. In-memory is fine for a single
# instance; use a shared store (e.g. redis://host:6379) for multi-instance
# deployments, otherwise each instance enforces its own separate limit.
LIMITER_STORAGE_URI=memory://

# ===================================================================
# LLM PROVIDER SELECTION (CRITICAL)
# ===================================================================
# Options: "ollama_only" (local only) or "standard" (with cloud fallbacks)
LLM_PROVIDER=ollama_only

# ===================================================================
# OLLAMA CONFIGURATION (Local Open Models)
# ===================================================================
# Ollama is now the primary LLM provider
OLLAMA_ENABLED=True
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral                 # Options: mistral, neural-chat, orca-mini, llama2
OLLAMA_TIMEOUT=120                   # Seconds - increase for slower hardware

# ===================================================================
# GROQ CONFIGURATION (Cloud LLM - fallback only)
# ===================================================================
# Get API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=60

# ===================================================================
# OPENAI CONFIGURATION (Cloud LLM - fallback only)
# ===================================================================
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_TIMEOUT=60

# ===================================================================
# IMAGE GENERATION CONFIGURATION
# ===================================================================
IMAGE_GENERATION_ENABLED=True
IMAGE_PROVIDER=auto                  # Options: runway, openai, auto
IMAGE_FALLBACK_PROVIDER_ENABLED=True
IMAGE_FALLBACK_PROVIDER_URL=https://image.pollinations.ai/prompt

# ===================================================================
# RUNWAY AI IMAGE GENERATION (Optional - for video/image generation)
# ===================================================================
# Get API key from: https://runwayml.com
RUNWAY_API_KEY=your_runway_api_key_here
RUNWAY_API_URL=https://api.dev.runwayml.com/v1
RUNWAY_MODEL=gen4_image
RUNWAY_TIMEOUT=90
RUNWAY_POLL_ATTEMPTS=8
RUNWAY_POLL_INTERVAL_SECONDS=1.5
RUNWAY_STRICT_MODE=False             # If True, only use Runway (fail if unavailable)

# ===================================================================
# SERPER WEB SEARCH (For internet queries in chat modes)
# ===================================================================
# Get API key from: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here
SERPER_ENABLED=True

# ===================================================================
# NEWS API (For real-time news in chat modes)
# ===================================================================
# Get API key from: https://newsapi.org
NEWS_API_KEY=your_news_api_key_here

# ===================================================================
# DEVELOPMENT MODE (Testing without real API keys)
# ===================================================================
# IMPORTANT: Should ALWAYS be False in production!
# When True, responses are mocked (for testing only)
DEVELOPMENT_MODE=False

# ===================================================================
# MODEL ROUTING CONFIGURATION (Advanced - Optional)
# ===================================================================
# Default model to use (can be ollama:model_name or groq:model_name)
DEFAULT_MODEL_KEY=ollama:mistral
DEFAULT_MODEL_FALLBACKS=ollama:mistral,ollama:neural-chat,groq:llama-3.1-8b-instant

# Classifier model for chat mode detection
CLASSIFIER_MODEL_KEY=ollama:mistral
CLASSIFIER_FALLBACKS=ollama:mistral,ollama:neural-chat,groq:llama-3.1-8b-instant

# Light model (fast, lower quality) for simple tasks
MODEL_PROFILE_LIGHT_KEY=ollama:mistral
MODEL_PROFILE_LIGHT_FALLBACKS=ollama:mistral,ollama:neural-chat,groq:llama-3.1-8b-instant

# Heavy model (slower, higher quality) for complex tasks
MODEL_PROFILE_HEAVY_KEY=ollama:mistral
MODEL_PROFILE_HEAVY_FALLBACKS=ollama:mistral,groq:llama3-70b-8192

# ===================================================================
# RAG SYSTEM CONFIGURATION (Retrieval-Augmented Generation)
# ===================================================================
RAG_ENABLED=True
RAG_UPDATE_INTERVAL=3600             # Update knowledge base every hour
RAG_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
RAG_FAISS_INDEX_PATH=./temp/rag_index.faiss

# ===================================================================
# LANGUAGE SUPPORT
# ===================================================================
# Supported languages for multilingual chat
SUPPORTED_LANGUAGES=en,hi,ta,te,kn   # English, Hindi, Tamil, Telugu, Kannada

# ===================================================================
# DATABASE CONFIGURATION (If using SQLite or external DB)
# ===================================================================
DATABASE_URL=sqlite:///./data/chatbot.db

# ===================================================================
# JWT AUTHENTICATION
# ===================================================================
JWT_SECRET=your-super-secure-random-jwt-key-change-me-in-production
JWT_EXPIRATION_DAYS=7

# ===================================================================
# NOTES FOR DEPLOYMENT
# ===================================================================
# 1. set LLM_PROVIDER=ollama_only for local inference (no cloud APIs needed)
# 2. Ensure Ollama is running: ollama serve
# 3. Pull required model: ollama pull mistral
# 4. Set OLLAMA_API_URL to accessible Ollama instance
# 5. For cloud deployment, add Groq/OpenAI keys as fallbacks
# 6. ALWAYS set FLASK_DEBUG=False in production
# 7. ALWAYS set DEVELOPMENT_MODE=False in production
# 8. Use strong API keys with appropriate permissions
# 9. Store .env securely - never commit to version control
# 10. Use environment variables for secrets in production (avoid .env files)
